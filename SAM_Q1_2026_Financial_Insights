<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sentinel Asset Management — Q1 2026 Financial Review</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy:    #04313f;
    --teal:    #73888c;
    --grey:    #524f46;
    --green:   #0f3f24;
    --bone:    #ece9e4;
    --bone-dk: #d8d4cd;
    --white:   #ffffff;
    --danger:  #7a2e2e;
    --warn:    #6b4e1a;
    --good:    #0f3f24;
    --navy-lt: #0a4f63;
  }

  html { font-size: 16px; }

  body {
    font-family: 'DM Sans', Arial, sans-serif;
    font-weight: 300;
    background: var(--bone);
    color: var(--grey);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  /* ── COVER ─────────────────────────────────────────────── */
  .cover {
    background: var(--navy);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 48px 64px;
    position: relative;
    overflow: hidden;
  }

  .cover::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 45%;
    height: 100%;
    background: linear-gradient(135deg, transparent 40%, rgba(15,63,36,0.25) 100%);
    pointer-events: none;
  }

  .cover-rule {
    width: 100%;
    height: 0.5px;
    background: rgba(236,233,228,0.3);
  }

  .cover-logo-area {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .cover-helmet {
    width: 42px;
    height: 42px;
    opacity: 0.9;
  }

  .cover-wordmark {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .cover-sentinel {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 300;
    color: var(--bone);
    letter-spacing: 0.18em;
    line-height: 1;
  }

  .cover-sub-brand {
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(236,233,228,0.55);
    font-weight: 300;
  }

  .cover-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 0 60px;
  }

  .cover-eyebrow {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(115,136,140,0.9);
    margin-bottom: 20px;
    font-weight: 300;
  }

  .cover-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(48px, 7vw, 80px);
    font-weight: 300;
    color: var(--bone);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: 32px;
  }

  .cover-title em {
    font-style: italic;
    color: rgba(115,136,140,0.8);
  }

  .cover-meta {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
  }

  .cover-meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cover-meta-label {
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(115,136,140,0.7);
    font-weight: 300;
  }

  .cover-meta-value {
    font-size: 14px;
    color: rgba(236,233,228,0.8);
    font-weight: 300;
  }

  .cover-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cover-confidential {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(115,136,140,0.6);
  }

  .cover-page {
    font-size: 10px;
    color: rgba(115,136,140,0.4);
  }

  /* ── LAYOUT ─────────────────────────────────────────────── */
  .doc-wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 48px;
  }

  /* ── PAGE HEADER (repeating) ─────────────────────────────── */
  .page-header {
    background: var(--navy);
    padding: 18px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .page-header-logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .page-header-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px;
    letter-spacing: 0.14em;
    color: rgba(236,233,228,0.8);
    font-weight: 300;
  }

  .page-header-section {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(115,136,140,0.7);
  }

  /* ── SECTION BLOCKS ─────────────────────────────────────── */
  .section {
    padding: 64px 0 48px;
    border-bottom: 0.5px solid var(--bone-dk);
  }

  .section:last-child {
    border-bottom: none;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 36px;
  }

  .section-num {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--teal);
    font-weight: 400;
    min-width: 24px;
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 300;
    color: var(--navy);
    letter-spacing: 0.02em;
    flex: 1;
  }

  .section-rule {
    flex: 1;
    height: 0.5px;
    background: var(--bone-dk);
  }

  /* ── HEALTH DASHBOARD ───────────────────────────────────── */
  .health-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--bone-dk);
    border: 1px solid var(--bone-dk);
    margin-bottom: 12px;
  }

  .health-cell {
    background: var(--bone);
    padding: 24px 22px;
    border-left: 3px solid transparent;
  }

  .health-cell.red   { border-left-color: #8b3a3a; }
  .health-cell.amber { border-left-color: #8b6914; }
  .health-cell.green { border-left-color: var(--green); }

  .health-indicator {
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 400;
    margin-bottom: 8px;
  }
  .health-cell.red   .health-indicator { color: #8b3a3a; }
  .health-cell.amber .health-indicator { color: #8b6914; }
  .health-cell.green .health-indicator { color: var(--green); }

  .health-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px;
    font-weight: 400;
    color: var(--navy);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .health-body {
    font-size: 12.5px;
    color: var(--grey);
    line-height: 1.65;
  }

  /* ── METRIC CARDS ───────────────────────────────────────── */
  .metric-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 36px;
  }

  .metric-row-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 36px;
  }

  .metric-card {
    background: var(--white);
    border: 0.5px solid var(--bone-dk);
    padding: 20px 20px 18px;
  }

  .metric-label {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 10px;
    font-weight: 400;
    line-height: 1.4;
  }

  .metric-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 30px;
    font-weight: 300;
    color: var(--navy);
    line-height: 1;
    margin-bottom: 6px;
  }

  .metric-sub {
    font-size: 12px;
    color: var(--teal);
    line-height: 1.4;
  }

  .badge {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.06em;
    padding: 2px 7px;
    font-weight: 400;
    vertical-align: middle;
  }

  .badge-red   { background: #f2e8e8; color: #8b3a3a; }
  .badge-green { background: #e3ede6; color: var(--green); }
  .badge-amber { background: #f0eada; color: #7a5a14; }

  /* ── CHARTS ─────────────────────────────────────────────── */
  .chart-container {
    background: var(--white);
    border: 0.5px solid var(--bone-dk);
    padding: 28px 24px 20px;
    margin-bottom: 12px;
  }

  .chart-title {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 20px;
    font-weight: 400;
  }

  .chart-legend {
    display: flex;
    gap: 20px;
    margin-top: 14px;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11.5px;
    color: var(--teal);
  }

  .legend-swatch {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
  }

  .chart-wrap { position: relative; width: 100%; }

  /* ── TABLES ─────────────────────────────────────────────── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 36px;
  }

  .tbl-wrap {
    background: var(--white);
    border: 0.5px solid var(--bone-dk);
    overflow: hidden;
  }

  .tbl-head {
    background: var(--navy);
    padding: 12px 18px;
  }

  .tbl-head-title {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(236,233,228,0.7);
    font-weight: 300;
  }

  table.data {
    width: 100%;
    border-collapse: collapse;
    font-size: 12.5px;
  }

  table.data tr {
    border-bottom: 0.5px solid var(--bone-dk);
  }

  table.data tr:last-child {
    border-bottom: none;
  }

  table.data td {
    padding: 9px 18px;
    color: var(--grey);
    line-height: 1.4;
  }

  table.data td:last-child {
    text-align: right;
    color: var(--navy);
    font-weight: 400;
  }

  table.data tr.total-row {
    background: rgba(4,49,63,0.04);
    border-top: 1px solid var(--bone-dk);
  }

  table.data tr.total-row td {
    font-weight: 400;
    color: var(--navy);
  }

  table.data tr.indent td:first-child {
    padding-left: 30px;
    color: var(--teal);
    font-size: 12px;
  }

  .val-red   { color: #8b3a3a !important; }
  .val-green { color: var(--green) !important; }

  /* ── AUM SCENARIO ───────────────────────────────────────── */
  .aum-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 12px;
  }

  .aum-card {
    background: var(--white);
    border: 0.5px solid var(--bone-dk);
    overflow: hidden;
  }

  .aum-card.preferred {
    border-color: var(--green);
  }

  .aum-card-header {
    background: var(--navy);
    padding: 18px 22px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .aum-card.preferred .aum-card-header {
    background: var(--green);
  }

  .aum-scenario-label {
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(236,233,228,0.55);
    margin-bottom: 4px;
  }

  .aum-fee-rate {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    color: var(--bone);
    line-height: 1;
  }

  .aum-badge {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 9px;
    border: 0.5px solid rgba(236,233,228,0.35);
    color: rgba(236,233,228,0.7);
    font-weight: 300;
  }

  .aum-body {
    padding: 20px 22px;
  }

  .aum-row {
    display: flex;
    justify-content: space-between;
    padding: 7px 0;
    border-bottom: 0.5px solid var(--bone-dk);
    font-size: 12.5px;
  }

  .aum-row:last-child {
    border-bottom: none;
    padding-top: 12px;
  }

  .aum-row-label {
    color: var(--teal);
  }

  .aum-row-val {
    color: var(--navy);
    font-weight: 400;
  }

  .aum-result {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-weight: 300;
    color: var(--navy);
  }

  .progress-track {
    background: var(--bone-dk);
    height: 3px;
    margin-top: 14px;
    margin-bottom: 6px;
  }

  .progress-fill {
    height: 3px;
    background: var(--navy);
  }

  .aum-card.preferred .progress-fill {
    background: var(--green);
  }

  .progress-label {
    font-size: 10px;
    color: var(--teal);
    letter-spacing: 0.06em;
  }

  .aum-note {
    font-size: 12px;
    color: var(--teal);
    line-height: 1.65;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 0.5px solid var(--bone-dk);
  }

  .slider-section {
    background: var(--white);
    border: 0.5px solid var(--bone-dk);
    padding: 22px 24px;
    margin-bottom: 16px;
  }

  .slider-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .slider-heading {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--teal);
    font-weight: 400;
  }

  .slider-val-display {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 300;
    color: var(--navy);
  }

  input[type=range] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 2px;
    background: var(--bone-dk);
    outline: none;
    cursor: pointer;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 14px;
    background: var(--navy);
    border-radius: 50%;
    cursor: pointer;
  }

  input[type=range]::-moz-range-thumb {
    width: 14px;
    height: 14px;
    background: var(--navy);
    border-radius: 50%;
    border: none;
    cursor: pointer;
  }

  /* ── INSIGHTS ───────────────────────────────────────────── */
  .insight-card {
    background: var(--white);
    border: 0.5px solid var(--bone-dk);
    border-left: 3px solid var(--navy);
    padding: 26px 28px;
    margin-bottom: 12px;
  }

  .insight-priority {
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 8px;
    font-weight: 400;
  }

  .insight-priority.critical { color: #8b3a3a; }
  .insight-priority.structural { color: var(--navy); }

  .insight-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 19px;
    font-weight: 400;
    color: var(--navy);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .insight-body {
    font-size: 13.5px;
    color: var(--grey);
    line-height: 1.75;
  }

  /* ── BALANCE SHEET ───────────────────────────────────────── */
  .bs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  /* ── FOOTNOTE ───────────────────────────────────────────── */
  .footnote {
    font-size: 11px;
    color: var(--teal);
    line-height: 1.6;
    padding-top: 8px;
    font-style: italic;
  }

  /* ── DOCUMENT FOOTER ────────────────────────────────────── */
  .doc-footer {
    background: var(--navy);
    padding: 28px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 64px;
  }

  .doc-footer-left {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .doc-footer-firm {
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px;
    font-weight: 300;
    color: rgba(236,233,228,0.7);
    letter-spacing: 0.12em;
  }

  .doc-footer-conf {
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(115,136,140,0.6);
  }

  .doc-footer-right {
    font-size: 10px;
    color: rgba(115,136,140,0.5);
    text-align: right;
    line-height: 1.6;
  }

  /* ── INTRO / BODY TEXT ───────────────────────────────────── */
  .intro-text {
    font-size: 14px;
    color: var(--grey);
    line-height: 1.75;
    margin-bottom: 32px;
    max-width: 640px;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────── */
  @media (max-width: 720px) {
    .doc-wrap { padding: 0 20px; }
    .cover { padding: 28px 24px; }
    .page-header { padding: 14px 20px; }
    .health-grid { grid-template-columns: 1fr; }
    .metric-row, .metric-row-3 { grid-template-columns: 1fr 1fr; }
    .two-col, .aum-grid, .bs-grid { grid-template-columns: 1fr; }
    .cover-meta { gap: 20px; }
  }

  /* ── PASSWORD GATE ───────────────────────────────────────── */
  #pw-gate {
    position: fixed;
    inset: 0;
    background: var(--navy);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
  }

  #pw-gate::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 45%;
    height: 100%;
    background: linear-gradient(135deg, transparent 40%, rgba(15,63,36,0.2) 100%);
    pointer-events: none;
  }

  #pw-gate::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 0.5px;
    background: rgba(236,233,228,0.25);
  }

  .pw-bottom-rule {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 0.5px;
    background: rgba(236,233,228,0.25);
  }

  .pw-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin-bottom: 56px;
    position: relative;
    z-index: 1;
  }

  .pw-sentinel {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    color: var(--bone);
    letter-spacing: 0.22em;
    line-height: 1;
  }

  .pw-sub {
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(115,136,140,0.65);
    font-weight: 300;
  }

  .pw-box {
    width: 100%;
    max-width: 360px;
    position: relative;
    z-index: 1;
  }

  .pw-eyebrow {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(115,136,140,0.7);
    margin-bottom: 28px;
    text-align: center;
  }

  .pw-field-wrap {
    position: relative;
    margin-bottom: 12px;
  }

  .pw-field-label {
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(115,136,140,0.6);
    margin-bottom: 8px;
    display: block;
  }

  #pw-input {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 0.5px solid rgba(115,136,140,0.4);
    color: var(--bone);
    font-family: 'DM Sans', Arial, sans-serif;
    font-size: 14px;
    font-weight: 300;
    letter-spacing: 0.12em;
    padding: 14px 18px;
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }

  #pw-input::placeholder {
    color: rgba(115,136,140,0.35);
    letter-spacing: 0.08em;
  }

  #pw-input:focus {
    border-color: rgba(115,136,140,0.8);
    background: rgba(255,255,255,0.07);
  }

  #pw-input.shake {
    animation: shake 0.35s ease;
    border-color: rgba(139,58,58,0.8);
  }

  @keyframes shake {
    0%   { transform: translateX(0); }
    20%  { transform: translateX(-8px); }
    40%  { transform: translateX(8px); }
    60%  { transform: translateX(-6px); }
    80%  { transform: translateX(4px); }
    100% { transform: translateX(0); }
  }

  #pw-btn {
    width: 100%;
    background: transparent;
    border: 0.5px solid rgba(236,233,228,0.3);
    color: rgba(236,233,228,0.75);
    font-family: 'DM Sans', Arial, sans-serif;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 14px 18px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    margin-top: 4px;
  }

  #pw-btn:hover {
    background: rgba(236,233,228,0.06);
    border-color: rgba(236,233,228,0.5);
    color: var(--bone);
  }

  #pw-btn:active {
    background: rgba(236,233,228,0.1);
  }

